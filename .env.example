# Database Configuration
POSTGRES_USER=treasury
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=treasury
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Application Settings
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Security - CORS
# Comma-separated list of allowed origins for production (e.g., https://yourdomain.com)
# Leave empty in development to allow all origins
ALLOWED_ORIGINS=

# Scheduler Settings
# Timezone for when to check for daily updates (Treasury publishes ~3:30 PM ET)
# Uses IANA timezone format: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
CRON_TZ=America/New_York
# When to check for daily data (24-hour format, local to CRON_TZ)
SCHEDULER_CRON_HOUR=16
SCHEDULER_CRON_MINUTE=30
# How often to check for updates when not at cron time (milliseconds, default 15 min)
SCHEDULER_CHECK_INTERVAL_MS=900000

# Rate Limiting
# Maximum requests per IP per window
RATE_LIMIT_MAX=100
# Window size in milliseconds (60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Comma-separated list of trusted proxy IPs (for X-Forwarded-For validation)
# In production with Traefik, this should be the internal network IP of your Traefik container
# Example: 172.16.0.0/12 or specific IP like 10.0.0.1
TRUSTED_PROXY_IPS=

# Cloudflare (Production only - for SSL via DNS challenge)
# Get your API token from: https://dash.cloudflare.com/profile/api-tokens
# Traefik v3 expects CF_API_TOKEN env var for Cloudflare DNS challenge
CF_API_EMAIL=your_email@example.com
CF_API_TOKEN=your_cloudflare_api_token

# Domain (Production only)
DOMAIN=yourdomain.com
